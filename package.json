{
  "name": "sochno-crm",
  "version": "0.1.3",
  "description": "СОЧНО CRM — десктопная CRM для веб-студии (Electron + SQLite)",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --publish never",
    "build:dir": "vite build && electron-builder --dir",
    "release": "vite build && electron-builder --publish always",
    "start": "electron .",
    "setup-native": "node scripts/setup-native.mjs",
    "postinstall": "node scripts/setup-native.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-updater": "^6.8.9",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.7.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
